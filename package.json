{
  "name": "zeta",
  "private": true,
  "scripts": {
    "clean": "find . ( -name node_modules -o -name .turbo -o -name .next  -o -name .vite -o -name dist -o -name out ) -type d -prune -exec rm -rf '{}' +",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx,json,md,yml,yaml}\"",
    "gen:workspace": "turbo generate workspace",
    "gen:workspace:ts-lib": "turbo generate workspace --type package --copy @zeta/template-ts-lib --destination packages",
    "gen:workspace:react-ui": "turbo generate workspace --type package --copy @zeta/template-react-ui --destination packages",
    "gen:react-package": "turbo generate run react-package --config tools/generators/config.ts",
    "worktrees:clean": "bash ./tools/clean-worktrees.sh"
  },
  "devDependencies": {
    "turbo": "^2.8.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@openai/codex": "^0.104.0"
  }
}
